// "Freeman Style Monologue"
// 30-секундный минималистичный ролик. Используем проверенные ресурсы marshal и server-dark.

import character marshal from "assets/characters/procedural/marshal.json"
import set server-dark from "assets/sets/server-dark.svg"

config {
    width: 1920
    height: 1080
    fps: 30
    background: #050505 // Почти черный фон для атмосферы Фримена
}

// --- ПОЗЫ В СТИЛЕ ФРИМЕНА ---

pose "freeman-stare" {
    torso-squash: 1.02
    line-of-action: 0.0
    head-nod: -2
    eye-open-left: 0.85
    eye-open-right: 0.85
    eyebrow-left: -0.3
    eyebrow-right: -0.3
    mouth-smile: -0.2 // Строгое выражение лица
}

pose "freeman-point" {
    torso-bend: 5
    arm-right-angle: -45 // Указывает прямо в камеру
    elbow-right-bend: 0.2
    head-nod: -5
    eye-open-left: 0.9
    eye-open-right: 0.9
}

// --- СЦЕНА (30 секунд) ---

scene "freeman-void" (duration: 30s, set: server-dark) {
    
    // 0-5 сек: Появление в темноте
    place marshal at center facing front
    marshal pose "freeman-stare"
    
    camera wide
    wait 3s
    camera medium
    wait 2s

    // 5-15 сек: Приближение и "обвинительный" жест
    together {
        camera zoom-to marshal over 3s ease-in-out
        marshal pose "freeman-point"
    }
    wait 4s

    // 15-22 сек: Экстремально крупный план (давление на зрителя)
    camera extreme-close-up marshal
    wait 4s

    // 22-28 сек: Возврат в спокойное состояние
    together {
        marshal pose "freeman-stare"
        camera zoom-to (0.5, 0.5) over 3s ease-out // Отъезд камеры
    }
    wait 3s

    // 28-30 сек: Финал
    camera wide
    wait 1s
    transition fade-black 1s
}
