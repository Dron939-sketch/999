// "The Freeman Monologue" (Visual Timing)
// 30-секундный ролик, выверенный под закадровый голос.

config {
    width: 1920
    height: 1080
    fps: 30
    background: #000000
}

// Простая поза для статичного наблюдения
pose "freeman-stare" {
    torso-bend: 0
    head-nod: 0
    arm-left-angle: -10
    arm-right-angle: 10
    elbow-left-bend: 0.1
    elbow-right-bend: 0.1
    eye-open-left: 0.9
    eye-open-right: 0.9
    mouth-smile: 0.0
}

scene "freeman-void" (duration: 30s, set: server-dark) {
    // 0-5 сек: Вступление ("Привет. Ты думаешь, что пишешь код.")
    camera wide
    wait 2s
    camera medium
    wait 3s

    // 5-15 сек: Поворот ("Но на самом деле... код пишет тебя.")
    camera close-up
    wait 2s
    camera extreme-close-up
    wait 3s

    // 15-25 сек: Кульминация ("Каждая строка — это клетка. А ты привыкаешь к решетке.")
    camera medium
    wait 3s
    camera wide
    wait 3s

    // 25-30 сек: Финал ("Продолжай.")
    camera close-up
    wait 2s
    
    transition fade-black 2s
}
