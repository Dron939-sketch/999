character "fred" {
    body-type: adult-male
    skin-color: light
    hair-style: slicked-back
    hair-color: dark
    clothing: overcoat
    clothing-color: dark-gray
    pants-color: dark-gray
    accessories: none
}

pose "thinking" {
    torso-bend: 5
    head-nod: 10
    arm-left-angle: -30
    arm-right-angle: 30
    elbow-left-bend: 0.6
    elbow-right-bend: 0.6
    mouth-smile: 0.1
}

scene "intro" {
    duration: 5
    set: dark-room
    
    place fred at center facing front
    camera wide
    wait 2
    text "Это тестовая анимация." at top
    wait 2
    transition fade-black 1
}
